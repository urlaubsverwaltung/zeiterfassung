{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ES2015",
    "lib": ["ESNext", "dom", "dom.iterable"],
    "moduleResolution": "Node",
    "types": ["node", "svelte"]
  },
  "include": [
    "types.d.ts",
    "src/main/javascript/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
