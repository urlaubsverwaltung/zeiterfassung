{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2017",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "types.d.ts",
    "src/main/javascript/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
