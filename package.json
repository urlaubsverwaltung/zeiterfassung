{
  "private": true,
  "name": "@focus-shift/zeiterfassung",
  "scripts": {
    "build": "concurrently 'npm:lint:*' 'npm:build:*' -c 'bgRed.bold,bgBlue.bold'",
    "build:js": "rollup -c",
    "build:css": "postcss src/main/css/*.css --base src/main/css --dir target/classes/static",
    "dev": "concurrently 'npm:lint:ts -- --watch' 'npm:dev:*' -c 'bgRed.bold,bgBlue.bold'",
    "dev:js": "npm run build:js -- -w",
    "dev:css": "npm run build:css -- --watch",
    "lint": "concurrently 'npm:lint:*'",
    "lint:eslint": "eslint .",
    "lint:ts": "tsc -noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write src/main/javascript"
  },
  "dependencies": {
    "@duetds/date-picker": "1.4.0",
    "@eslint/compat": "2.0.1",
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "9.39.2",
    "@hotwired/turbo": "8.0.23",
    "@popperjs/core": "2.11.8",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@tailwindcss/postcss": "4.2.1",
    "@types/hotwired__turbo": "8.0.9",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "@ungap/custom-elements": "1.3.0",
    "@vitest/coverage-v8": "4.1.0",
    "concurrently": "9.2.1",
    "cssnano": "7.1.3",
    "date-fns": "3.6.0",
    "esbuild": "0.27.4",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unicorn": "62.0.0",
    "fast-glob": "3.3.3",
    "globals": "17.4.0",
    "idiomorph": "0.7.4",
    "jsdom": "29.0.0",
    "lint-staged": "16.4.0",
    "postcss": "8.5.8",
    "postcss-cli": "11.0.1",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "rollup": "4.59.0",
    "rollup-plugin-esbuild": "6.2.1",
    "rollup-plugin-postcss": "4.0.2",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.1.0"
  },
  "lint-staged": {
    "*.{js,mjs,ts,html,svg,css}": [
      "prettier --write"
    ]
  }
}
