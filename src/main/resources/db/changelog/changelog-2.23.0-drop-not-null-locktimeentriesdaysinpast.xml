<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

  <changeSet author="seber" id="drop-not-null-locktimeentriesdaysinpast">
    <preConditions>
      <columnExists tableName="settings_locking_time_entries" columnName="lock_time_entries_days_in_past"/>
    </preConditions>
    <dropNotNullConstraint tableName="settings_locking_time_entries" columnName="lock_time_entries_days_in_past" />
  </changeSet>

  <changeSet author="seber" id="migrate-actual-null-locktimeentriesdaysinpast">
    <preConditions>
      <columnExists tableName="settings_locking_time_entries" columnName="lock_time_entries_days_in_past"/>
    </preConditions>
    <update tableName="settings_locking_time_entries">
      <column name="lock_time_entries_days_in_past" value="null"/>
      <where>lock_time_entries_days_in_past=-1</where>
    </update>
  </changeSet>

</databaseChangeLog>
