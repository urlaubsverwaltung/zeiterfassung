<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

  <changeSet author="slint" id="add-github-installation-id-to-user-settings">
    <preConditions onFail="MARK_RAN">
      <not><columnExists tableName="user_settings" columnName="github_installation_id"/></not>
    </preConditions>
    <addColumn tableName="user_settings">
      <column name="github_installation_id" type="BIGINT">
        <constraints nullable="true"/>
      </column>
    </addColumn>
  </changeSet>

</databaseChangeLog>
