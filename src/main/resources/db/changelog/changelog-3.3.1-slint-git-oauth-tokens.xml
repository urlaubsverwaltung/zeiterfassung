<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

  <changeSet author="slint" id="git-activity-add-oauth-token-table">
    <preConditions onFail="MARK_RAN">
      <not><tableExists tableName="git_oauth_token"/></not>
    </preConditions>

    <createSequence sequenceName="git_oauth_token_seq" startValue="1" incrementBy="50"/>

    <createTable tableName="git_oauth_token">
      <column name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true" primaryKeyName="git_oauth_token_pkey"/>
      </column>
      <column name="platform" type="VARCHAR(20)">
        <constraints nullable="false"/>
      </column>
      <column name="user_local_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="platform_account_id" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="access_token" type="TEXT">
        <constraints nullable="false"/>
      </column>
      <column name="refresh_token" type="TEXT">
        <constraints nullable="true"/>
      </column>
      <column name="expires_at" type="TIMESTAMP WITH TIME ZONE">
        <constraints nullable="true"/>
      </column>
    </createTable>

    <addUniqueConstraint tableName="git_oauth_token"
                         columnNames="platform, user_local_id"
                         constraintName="uq_git_oauth_token_platform_user"/>

    <addUniqueConstraint tableName="git_oauth_token"
                         columnNames="platform, platform_account_id"
                         constraintName="uq_git_oauth_token_platform_account"/>
  </changeSet>

</databaseChangeLog>
