<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

  <changeSet author="slint" id="git-activity-add-platform-column">
    <preConditions onFail="MARK_RAN">
      <not><columnExists tableName="github_raw_event" columnName="platform"/></not>
    </preConditions>

    <addColumn tableName="github_raw_event">
      <column name="platform" type="VARCHAR(20)" defaultValue="GITHUB">
        <constraints nullable="false"/>
      </column>
    </addColumn>
  </changeSet>

</databaseChangeLog>
