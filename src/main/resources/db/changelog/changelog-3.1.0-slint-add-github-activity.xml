<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

  <changeSet author="slint" id="add-github-raw-event-table">
    <preConditions onFail="MARK_RAN">
      <not><tableExists tableName="github_raw_event"/></not>
    </preConditions>

    <createSequence sequenceName="github_raw_event_seq" startValue="1" incrementBy="50"/>

    <createTable tableName="github_raw_event">
      <column name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true" primaryKeyName="github_raw_event_pkey"/>
      </column>
      <column name="github_event_id" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="github_username" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="event_type" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <column name="repo_name" type="VARCHAR(500)">
        <constraints nullable="false"/>
      </column>
      <column name="anchor_type" type="VARCHAR(20)">
        <constraints nullable="false"/>
      </column>
      <column name="anchor_id" type="VARCHAR(255)">
        <constraints nullable="true"/>
      </column>
      <column name="anchor_title" type="VARCHAR(500)">
        <constraints nullable="true"/>
      </column>
      <column name="event_icon" type="VARCHAR(10)">
        <constraints nullable="false"/>
      </column>
      <column name="event_summary" type="VARCHAR(1000)">
        <constraints nullable="false"/>
      </column>
      <column name="event_timestamp" type="TIMESTAMP WITH TIME ZONE">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addUniqueConstraint tableName="github_raw_event" columnNames="github_event_id"
                         constraintName="uq_github_raw_event_event_id"/>

    <createIndex tableName="github_raw_event" indexName="idx_github_raw_event_username_timestamp">
      <column name="github_username"/>
      <column name="event_timestamp"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
