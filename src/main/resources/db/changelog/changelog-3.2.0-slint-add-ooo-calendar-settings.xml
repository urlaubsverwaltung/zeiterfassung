<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="create-settings-ooo-calendar-table" author="slint">
    <createTable tableName="settings_ooo_calendar">
      <column name="id" type="BIGINT" autoIncrement="false">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="tenant_id" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="calendar_url" type="VARCHAR(2048)"/>
    </createTable>
    <createSequence sequenceName="settings_ooo_calendar_seq" startValue="1" incrementBy="1"/>
  </changeSet>

  <changeSet id="alter-settings-ooo-calendar-seq-increment" author="slint">
    <!-- Hibernate default allocationSize is 50; sequence must match -->
    <sql>ALTER SEQUENCE settings_ooo_calendar_seq INCREMENT BY 50</sql>
  </changeSet>

</databaseChangeLog>
