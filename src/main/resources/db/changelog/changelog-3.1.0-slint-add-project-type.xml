<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

  <changeSet author="slint" id="add-project-type-table">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="project_type" />
      </not>
    </preConditions>

    <createSequence sequenceName="project_type_seq" startValue="1" incrementBy="50"/>

    <createTable tableName="project_type">
      <column name="tenant_id" type="VARCHAR(255)"/>
      <column name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true" primaryKeyName="project_type_pkey"/>
      </column>
      <column name="name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="active" type="BOOLEAN" defaultValueBoolean="true">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint
      constraintName="FK_PROJECT_TYPE_TENANT_ID"
      baseColumnNames="tenant_id"
      baseTableName="project_type"
      referencedColumnNames="tenant_id"
      referencedTableName="tenant"
      deferrable="false"
      initiallyDeferred="false"
      onDelete="CASCADE"
      onUpdate="NO ACTION"
    />
  </changeSet>

  <changeSet author="slint" id="enable-row-level-security-on-project-type">
    <sql dbms="postgresql">
      ALTER TABLE project_type ENABLE ROW LEVEL SECURITY;
      DROP
      POLICY IF EXISTS project_type_tenant_isolation_policy ON project_type;
            CREATE
      POLICY project_type_tenant_isolation_policy ON project_type
                USING (tenant_id = current_setting('app.tenant_id')::VARCHAR);
    </sql>
  </changeSet>

</databaseChangeLog>
