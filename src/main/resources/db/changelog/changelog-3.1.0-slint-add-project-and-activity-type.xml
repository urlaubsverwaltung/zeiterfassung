<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

  <!-- Rename project_type → activity_type -->
  <changeSet author="slint" id="rename-project-type-table-to-activity-type">
    <preConditions onFail="MARK_RAN">
      <tableExists tableName="project_type"/>
      <not><tableExists tableName="activity_type"/></not>
    </preConditions>
    <renameTable oldTableName="project_type" newTableName="activity_type"/>
  </changeSet>

  <changeSet author="slint" id="rename-project-type-seq-to-activity-type-seq">
    <preConditions onFail="MARK_RAN">
      <sequenceExists sequenceName="project_type_seq"/>
      <not><sequenceExists sequenceName="activity_type_seq"/></not>
    </preConditions>
    <sql dbms="postgresql">ALTER SEQUENCE project_type_seq RENAME TO activity_type_seq;</sql>
  </changeSet>

  <!-- Rename time_entry.project_type_id → activity_type_id -->
  <changeSet author="slint" id="rename-time-entry-project-type-id-to-activity-type-id">
    <preConditions onFail="MARK_RAN">
      <columnExists tableName="time_entry" columnName="project_type_id"/>
      <not><columnExists tableName="time_entry" columnName="activity_type_id"/></not>
    </preConditions>
    <dropForeignKeyConstraint baseTableName="time_entry" constraintName="FK_TIME_ENTRY_PROJECT_TYPE_ID"/>
    <renameColumn tableName="time_entry" oldColumnName="project_type_id" newColumnName="activity_type_id" columnDataType="BIGINT"/>
    <addForeignKeyConstraint
      constraintName="FK_TIME_ENTRY_ACTIVITY_TYPE_ID"
      baseColumnNames="activity_type_id"
      baseTableName="time_entry"
      referencedColumnNames="id"
      referencedTableName="activity_type"
      deferrable="false"
      initiallyDeferred="false"
      onDelete="SET NULL"
      onUpdate="NO ACTION"
    />
  </changeSet>

  <!-- Create project table -->
  <changeSet author="slint" id="add-project-table">
    <preConditions onFail="MARK_RAN">
      <not><tableExists tableName="project"/></not>
    </preConditions>

    <createSequence sequenceName="project_seq" startValue="1" incrementBy="50"/>

    <createTable tableName="project">
      <column name="tenant_id" type="VARCHAR(255)"/>
      <column name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true" primaryKeyName="project_pkey"/>
      </column>
      <column name="name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="active" type="BOOLEAN" defaultValueBoolean="true">
        <constraints nullable="false"/>
      </column>
      <column name="customer_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint
      constraintName="FK_PROJECT_TENANT_ID"
      baseColumnNames="tenant_id"
      baseTableName="project"
      referencedColumnNames="tenant_id"
      referencedTableName="tenant"
      deferrable="false"
      initiallyDeferred="false"
      onDelete="CASCADE"
      onUpdate="NO ACTION"
    />

    <addForeignKeyConstraint
      constraintName="FK_PROJECT_CUSTOMER_ID"
      baseColumnNames="customer_id"
      baseTableName="project"
      referencedColumnNames="id"
      referencedTableName="customer"
      deferrable="false"
      initiallyDeferred="false"
      onDelete="CASCADE"
      onUpdate="NO ACTION"
    />
  </changeSet>

  <changeSet author="slint" id="enable-row-level-security-on-project">
    <sql dbms="postgresql">
      ALTER TABLE project ENABLE ROW LEVEL SECURITY;
      DROP POLICY IF EXISTS project_tenant_isolation_policy ON project;
      CREATE POLICY project_tenant_isolation_policy ON project
        USING (tenant_id = current_setting('app.tenant_id')::VARCHAR);
    </sql>
  </changeSet>

  <!-- Add project_id to time_entry -->
  <changeSet author="slint" id="add-project-id-to-time-entry">
    <preConditions onFail="MARK_RAN">
      <not><columnExists tableName="time_entry" columnName="project_id"/></not>
    </preConditions>

    <addColumn tableName="time_entry">
      <column name="project_id" type="BIGINT">
        <constraints nullable="true"/>
      </column>
    </addColumn>

    <addForeignKeyConstraint
      constraintName="FK_TIME_ENTRY_PROJECT_ID"
      baseColumnNames="project_id"
      baseTableName="time_entry"
      referencedColumnNames="id"
      referencedTableName="project"
      deferrable="false"
      initiallyDeferred="false"
      onDelete="SET NULL"
      onUpdate="NO ACTION"
    />
  </changeSet>

</databaseChangeLog>
